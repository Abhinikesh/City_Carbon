# ─────────────────────────────────────────────────────
#  CityCarbon — Environment Variables
#  Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────────────

# OpenAQ API Key (Optional — free tier works without this)
# Sign up at: https://api.openaq.org/register
# Gives you higher rate limits (10,000 req/day free)
OPENAQ_API_KEY=your_openaq_key_here

# Electricity Maps API Key (Required for live electricity data)
# Sign up FREE at: https://api.electricitymap.org/
# Free tier: carbon intensity by zone
ELECTRICITY_MAP_KEY=your_electricity_map_key_here

# Port (default 3001)
PORT=3001
